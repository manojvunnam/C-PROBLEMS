#include<stdio.h>
int main(){
int n,x,i,position=-1;
int arr[100];
int *ptr;
printf("enter size of array:");
scanf("%d",&n);
printf("enter array elements:");
for(i=0;i<n;i++){
scanf("%d",&arr[i]);
}
printf("enter element to search:");
scanf("%d",&x);
ptr=arr;
for(i=0;i<n;i++){
if(*(ptr+i)==x){
position=i+1;
break;
}
}
printf("%d",position);
return 0;
}
