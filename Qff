#include <stdio.h>

int isValid(int board[9][9]) {
    int i, j, k;

    // Check rows
    for (i = 0; i < 9; i++) {
        int seen[10] = {0};
        for (j = 0; j < 9; j++) {
            if (board[i][j] < 1 || board[i][j] > 9)
                return 0;
            if (seen[board[i][j]])
                return 0;
            seen[board[i][j]] = 1;
        }
    }

    // Check columns
    for (j = 0; j < 9; j++) {
        int seen[10] = {0};
        for (i = 0; i < 9; i++) {
            if (seen[board[i][j]])
                return 0;
            seen[board[i][j]] = 1;
        }
    }

    // Check 3x3 subgrids
    for (i = 0; i < 9; i += 3) {
        for (j = 0; j < 9; j += 3) {
            int seen[10] = {0};
            int r, c;
            for (r = i; r < i + 3; r++) {
                for (c = j; c < j + 3; c++) {
                    if (seen[board[r][c]])
                        return 0;
                    seen[board[r][c]] = 1;
                }
            }
        }
    }

    return 1;
}

int main() {
    int board[9][9];
    int i, j;

    printf("Enter the Sudoku (9x9):\n");

    for (i = 0; i < 9; i++) {
        for (j = 0; j < 9; j++) {
            scanf("%d", &board[i][j]);
        }
    }

    if (isValid(board))
        printf("Valid Sudoku\n");
    else
        printf("Invalid Sudoku\n");

    return 0;
}
