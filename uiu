#include <stdio.h>
int main() {
    int n ,i,sum;
    scanf("%d",&n);
    if (n<=1){
    sum=0;}
    else{
    for (i=1;i<=n/2;i++){
        if (n%i==0){
        sum++;
        }
    }
    }
    if (sum==2){
        printf("prime number",n);
       } else{
        printf("not prime number",n);}
    
    return 0;
}
