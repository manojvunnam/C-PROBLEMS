#include <stdio.h>
float add(float s1,float s2,float s3,float s4){
    return(s1+s2+s3+s4);
}
float sub(float s1,float s2,float s3,float s4){
    return(s1-s2-s3-s4);
}
float mul(float s1,float s2,float s3,float s4){
    return(s1*s2*s3*s4);
}
float divi(float s1,float s2,float s3,float s4){
    return(s1/s2/s3/s4);
}
int main() {
printf("Addition = %f\n", add(2.0,3.0,2.0,3.0));
printf("Subtraction = %f\n", sub(2.0,3.0,2.0,3.0));
printf("Multiplication = %f\n", mul(2.0,3.0,2.0,3.0));
printf("Division = %f\n", divi(2.0,3.0,2.0,3.0));
    return 0;
}
